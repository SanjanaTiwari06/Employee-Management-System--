{{>header}}

{{>Navbar}}

<div class="container my-3">
    <h5 class="bg-secondary text-center text-light p-2">Create Employee Record</h5>
    <form action="{{#if data._id}}/update/{{data._id}}{{else}}/Store{{/if}}" method="post">
        <div class="row">
            <div class="col-12 mb-3">
                 <label for="">Name*</label>
                 <input type="text" name="name" value="{{data.name}}" placeholder="Enter Your Name" class="form-control{{#if errormsg.name}}bg-danger{{else}}bg-secondary{{/if}}" style="width: 100%;">
                 {{#if errormsg.name}}
                 <p class="text-danger">{{errormsg.name}}</p>
                 {{/if}}
            </div>
            <div class="col-6 mb-3">
                 <label for="">e-mail*</label>
                 <input type="email" name="email" value="{{data.email}}" placeholder="Enter Your E-mail" class="form-control{{#if errormsg.email}}bg-danger{{else}}bg-secondary{{/if}}" style="width: 100%;">
                 {{#if errormsg.email}}
                 <p class="text-danger">{{errormsg.email}}</p>
                 {{/if}}
            </div>
            <div class="col-6 mb-3">
                 <label for="">Phone*</label>
                 <input type="number"name="phone" value="{{data.phone}}" placeholder="Enter Your Phone Number" class="form-control{{#if errormsg.phone}}bg-danger{{else}}bg-secondary{{/if}}" style="width: 100%;">
                 {{#if errormsg.phone}}
                 <p class="text-danger">{{errormsg.phone}}</p>
                 {{/if}}
            </div>
            <div class="col-6 mb-3">
                 <label for="">Designation*</label>
                 <input type="text" name="designation" value="{{data.designation}}" placeholder="Enter Your Designation" class="form-control{{#if errormsg.designation}}bg-danger{{else}}bg-secondary{{/if}}" style="width: 100%;">
                 {{#if errormsg.designation}}
                 <p class="text-danger">{{errormsg.designation}}</p>
                 {{/if}}
            </div>
            <div class="col-6 mb-3">
                 <label for="">Salary*</label>
                 <input type="number"name="salary" value="{{data.salary}}" placeholder="Enter Your Salary" class="form-control{{#if errormsg.salary}}bg-danger{{else}}bg-secondary{{/if}}" style="width: 100%;">
                 {{#if errormsg.salary}}
                 <p class="text-danger">{{errormsg.salary}}</p>
                 {{/if}}
            </div>
            <div class="col-6 mb-3">
                 <label for="">City-Name*</label>
                 <input type="text" name="city" value="{{data.city}}" placeholder="Enter Your CIty Name" class="form-control border-secondary" style="width: 100%;">
                
            </div>
            <div class="col-6 mb-3">
                 <label for="">State-Name*</label>
                 <input type="text" name="state" value="{{data.state}}" placeholder="Enter Your State Name" class="form-control border-secondary" style="width: 100%;">
                 
            </div>

            <div class="col-12">
               <button type="submit" class="bg-secondary w-100 text-light">{{#if data._id}}Update{{else}}Submit{{/if}}</button>
            </div>
        </div>
    </form>
</div>

{{>Footer}}